<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Web Site</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <nav class="navbar">
        <h1 class="logo">MySite</h1>
        <ul class="nav-links" id="navLinks">
            <li><a href="#home">Ana Sayfa</a></li>
            <li><a href="#about">Hakkımda</a></li>
            <li><a href="#projects">Projeler</a></li>
            <li><a href="#contact">İletişim</a></li>
        </ul>
        <div class="menu-toggle" id="menuToggle">☰</div>
    </nav>
</header>

<section id="home" class="hero">
    <div class="hero-content">
        <h2>Modern Web Tasarım 🚀</h2>
        <p>HTML, CSS ve JavaScript ile güçlü arayüzler</p>
        <button onclick="showAlert()">Keşfet</button>
    </div>
</section>

<section id="about">
    <h2>Hakkımda</h2>
    <p>Frontend geliştiricisiyim. Responsive ve kullanıcı dostu arayüzler tasarlıyorum.</p>
</section>

<section id="projects">
    <h2>Projeler</h2>
    <div class="cards">
        <div class="card">
            <h3>Proje 1</h3>
            <p>Modern web tasarım örneği</p>
        </div>
        <div class="card">
            <h3>Proje 2</h3>
            <p>Responsive site çalışması</p>
        </div>
        <div class="card">
            <h3>Proje 3</h3>
            <p>JavaScript uygulaması</p>
        </div>
    </div>
</section>

<section id="contact">
    <h2>İletişim</h2>
    <form id="contactForm">
        <input type="text" placeholder="Adınız" required>
        <input type="email" placeholder="Email" required>
        <textarea placeholder="Mesajınız"></textarea>
        <button type="submit">Gönder</button>
    </form>
</section>

<footer>
    <p>© 2026 Modern Web Site</p>
</footer>

<script src="script.js"></script>
</body>
</html>